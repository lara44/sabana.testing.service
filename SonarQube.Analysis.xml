<?xml version="1.0" encoding="utf-8"?>
<SonarQubeAnalysisProperties
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns="http://www.sonarsource.com/msbuild/integration/2015/1">

  <!-- Update these values when enabling SonarQube in CI -->
  <Property Name="sonar.host.url">https://your-sonarqube-host</Property>
  <Property Name="sonar.projectKey">sabana.testing.service</Property>
  <Property Name="sonar.projectName">sabana.testing.service</Property>
  <Property Name="sonar.projectVersion">1.0.0</Property>

  <Property Name="sonar.sourceEncoding">UTF-8</Property>
  <Property Name="sonar.exclusions">**/obj/**,**/bin/**,**/Migrations/**,infrastructure/**,TestResults/**,Coverage/**,StrykerOutput/**,.vscode/**</Property>
  <Property Name="sonar.dotnet.excludeTestProjects">true</Property>

  <!-- Paths generated by dotnet test + test.runsettings -->
  <Property Name="sonar.cs.vstest.reportsPaths">TestResults/test-results.trx.xml</Property>
  <Property Name="sonar.cs.opencover.reportsPaths">TestResults/*/coverage.opencover.xml</Property>
  <Property Name="sonar.verbose">true</Property>
</SonarQubeAnalysisProperties>
